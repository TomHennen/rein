53mmain\u001b[C\u001b[39mdirectly),\u001b[Cand\u001b[Cpushing\u001b[24;3Hrequired\u001b[Cyour\u001b[Capproval\u001b[Cvia\u001b[C\u001b[38;5;153mrein declare 221\u001b[39m,\u001b[Cwhich\u001b[Cyou\u001b[Cgranted.\u001b[CThe\u001b[CPR\u001b[Cbody\u001b[Creferences\u001b[C#221\u001b[Crather\u001b[Cthan\u001b[Cclosing\u001b[Cit\u001b[C\u2014\u001b[CI\u001b[Cdidn't\u001b[Cwant\u001b[Cto\u001b[Cassume\u001b[Cthe\u001b[Cissue\u001b[Cshould\u001b[25;3Hauto-close on merge. Say the word if you'd rather it say \"Closes #221.\"\u001b[K\u001b[27;1H\u001b[38;5;174m\u273d\u001b[CHarmoni\u001b[38;5;216mzin\u001b[38;5;174mg\u2026 \u001b[38;5;246m(1m 6s \u00b7 \u2193\u001b[39m \u001b[38;5;246m1.5k tokens)\u001b[39m\u001b[K\u001b[30;3H"]
