[16.262657, "o", "\u001b[H\u001b[K\u001b[2;24H\u001b[38;5;174m \u2590\u001b[48;5;16m\u259b\u2588\u2588\u2588\u259c\u001b[49m\u258c\u001b[24C\u001b[1mWhat's new\u001b[m\u000f                                                                                             \u001b[3;24H\u001b[38;5;174m\u259d\u259c\u001b[48;5;16m\u2588\u001b[3C\u2588\u001b[49m\u259b\u2598\u001b[23C\u001b[39mAuto mode is\u001b[Cnow\u001b[Cavailable\u001b[Cwithout\u001b[C`CLAUDE_CODE_ENABLE_AUTO_MODE`\u001b[Copt-in\u001b[Con\u001b[CBedrock,\u001b[CVertex\u001b[CAI,\u001b[Cand\u001b[CFo\u2026\u001b[4;24H\u001b[38;5;174m  \u2598\u2598 \u259d\u259d  \u001b[23C\u001b[39mFixed th\u001b[2Cterminal freezing and keystrokes lagging while streaming responses containing v\u001b[Cry long list\u001b[5;10H\u001b[38;5;246mOpus 4.8 (1M context) \u00b7 Claude Max \u00b7 \u001b[15C\u001b[39mremo\u001b[2C \u001b[Ca\u001b[2Cged s\u001b[Cttings from a n\u001b[Cn-interactive run\u001b[C(`cl\u001b[Cude -p`, the SDK) be\u001b[2Cg permanently\u001b[Creco\u001b[6;10H\u001b[38;5;246mtom.hennen@gmail.com's Org\u001b[Cnization\u001b[39m  \u001b[9C\u001b[38;5;246m\u001b[3m/release-notes for more\u001b[m\u000f      \u001b[C    \u001b[C \u001b[C               \u001b[C   \u001b[C        \u001b[C    \u001b[C   \u001b[C    \u001b[C     \u001b[C           \u001b[C     \u001b[7;10H       \u001b[38;5;246m/tmp/re\u001b[Cn-de\u001b[Co-m6ozjlj5\u001b[39m     \u001b[11C                       \r\n\u001b[38;5;174m\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\u001b[9;1H\u001b[K\u001b[10;2H\u001b[38;5;220m\u26a0\u001b[C4 MCP servers need authentication\u001b[38;5;246m \u00b7 run /mcp\u001b[39m\u001b[11;2H\u001b[K\n\u001b[38;5;174m\u258e\u001b[CExtended through July 19\u001b[13;4H\u001b[39mWe're extending Claude Fable\u001b[C5\u001b[Caccess\u001b[Con\u001b[Call\u001b[Cpaid\u001b[Cplans,\u001b[Cas\u001b[Cwell\u001b[Cas\u001b[Ckeeping\u001b[CClaude\u001b[CCode\u2019s\u001b[Cweekly\u001b[Crate\u001b[Climits\u001b[C50%\u001b[Chigher,\u001b[Cthrough\u001b[CJuly\u001b[C19.\u001b[14;4H\u001b[K\nAs\u001b[Cbefore,\u001b[Cyou\u001b[Ccan\u001b[Cuse\u001b[Cup\u001b[Cto\u001b[Chalf\u001b[Cof\u001b[Cyour\u001b[Cweekly\u001b[Cusage\u001b[Climit\u001b[Con\u001b[CFable\u001b[C5.\u001b[CAfter\u001b[Cthat,\u001b[Cyou\u001b[Ccan\u001b[Ckeep\u001b[Cusing\u001b[CFable\u001b[C5\u001b[Cwith\u001b[Cusage\u001b[Ccredits,\u001b[Cor\u001b[Cswitch\u001b[Cto\u001b[Canother\u001b[16;4Hmodel to keep working within\u001b[Cyour\u001b[Cremaining limits.\u001b[K\u001b[17;4H\u001b[K\nMore\u001b[Cdetails\u001b[Chere:\u001b[Chttps://support.claude.com/en/articles/15424964-claude-fable-5-promotional-access\u001b[19;2H\u001b[K\r\n\u001b[38;5;239m\u001b[48;5;237m\u276f \u001b[38;5;231mAdd one short joke about credentials to jokes.md, then commit it, push it, and open a pull request. This is issue #206.\u001b[39m                                       \u001b[49m\u001b[21;1H\u001b[K\r\n\u001b[38;5;231m\u25cf\u001b[C\u001b[39mI'll\u001b[Cstart\u001b[Cby\u001b[Clooking\u001b[Cat\u001b[Cthe\u001b[Crepo\u001b[Cand\u001b[Cthe\u001b[Cexisting\u001b[Cjokes.md.\r\n\u001b[K\r\n\u001b[38;5;246m \u001b[C\u001b[39mRunning\u001b[C\u001b[1m1\u001b[C\u001b[m\u000fshell\u001b[Ccommand\u2026\u001b[25;2H\u001b[38;5;246m \u23bf  $ ls && echo \"---\" && cat jokes.md 2>/dev/null && echo \"---\" && git remote -v && git log --oneline -3\u001b[27;12H\u001b[38;5;174mula\u001b[7C\u001b[38;5;246m3\u001b[30;3H\u001b[m\u000f"]
