[22.591238, "o", "\u001b[H\u001b[K\u001b[2;24H\u001b[38;5;174m\u259d\u259c\u001b[48;5;16m\u2588\u001b[3C\u2588\u001b[49m\u259b\u2598\u001b[23C\u001b[39mAuto mode is\u001b[Cnow\u001b[Cavailable\u001b[Cwithout\u001b[C`CLAUDE_CODE_ENABLE_AUTO_MODE`\u001b[Copt-in\u001b[Con\u001b[CBedrock,\u001b[CVertex\u001b[CAI,\u001b[Cand\u001b[CFo\u2026\u001b[3;24H\u001b[38;5;174m  \u2598\u2598 \u259d\u259d  \u001b[23C\u001b[39mFixed th\u001b[2Cterminal freezing and keystrokes lagging while streaming responses containing v\u001b[Cry long list\u001b[4;10H\u001b[38;5;246mOpus 4.8 (1M context) \u00b7 Claude Max \u00b7 \u001b[15C\u001b[39mremo\u001b[2C \u001b[Ca\u001b[2Cged s\u001b[Cttings from a n\u001b[Cn-interactive run\u001b[C(`cl\u001b[Cude -p`, the SDK) be\u001b[2Cg permanently\u001b[Creco\u001b[5;10H\u001b[38;5;246mtom.hennen@gmail.com's Org\u001b[Cnization\u001b[39m  \u001b[9C\u001b[38;5;246m\u001b[3m/release-notes for more\u001b[m\u000f      \u001b[C    \u001b[C \u001b[C               \u001b[C   \u001b[C        \u001b[C    \u001b[C   \u001b[C    \u001b[C     \u001b[C           \u001b[C     \u001b[6;10H       \u001b[38;5;246m/tmp/re\u001b[Cn-de\u001b[Co-7xsjl34g\u001b[39m     \u001b[11C                       \r\n\u001b[38;5;174m\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u25