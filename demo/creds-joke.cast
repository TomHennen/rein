K\u001b[9;2H\u001b[38;5;174m\u258e\u001b[CExtended through July 19\u001b[10;2H\u258e\u001b[C\u001b[39mWe're extending Claude Fable 5 access on all\u001b[Cpaid\u001b[Cplans,\u001b[Cas\u001b[Cwell\u001b[Cas\u001b[Ckeeping\u001b[CClaude\u001b[CCode\u2019s\u001b[Cweekly\u001b[Crate\u001b[Climits\u001b[C50%\u001b[Chigher,\u001b[Cthrough\u001b[CJuly\u001b[C19.\u001b[11;2H\u001b[38;5;174m\u258e\u001b[12;4H\u001b[39mAs before, you can use up\u001b[Cto\u001b[Chalf\u001b[Cof\u001b[Cyour\u001b[Cweekly\u001b[Cusage\u001b[Climit\u001b[Con\u001b[CFable\u001b[C5.\u001b[CAfter\u001b[Cthat,\u001b[Cyou\u001b[Ccan\u001b[Ckeep\u001b[Cusing\u001b[CFable\u001b[C5\u001b[Cwith\u001b[Cusage\u001b[Ccredits,\u001b[Cor\u001b[Cswitch\u001b[Cto\u001b[Canother\u001b[13;4Hmodel\u001b[Cto keep working within\u001b[Cyour remai\u001b[Cing lim\u001b[Cts.\u001b[K\u001b[15;4HMore details here:\u001b[Chttps://support.claude.com/en/articles/15424964-claude-\u001b[Cable-5-prom\u001b[Ctional-acces\u001b[C\u001b[K\u001b[16;2H\u001b[K\r\n\u001b[38;5;239m\u001b[48;5;237m\u276f \u001b[38;5;231mAdd one short joke about credentials to jokes.md, then commit it, push it, and open a pull request. This is issue #206.\u001b[39m                                       \u001b[49m\u001b[18;2H\u001b[K\r\n\u001b[38;5;231m\u25cf\u001b[C\u001b[39mI'll\u001b[Cstart\u001b[Cby\u001b[Clooking\u001b[Cat\u001b[Cthe\u001b[Crepo\u001b[Cand\u001b[Cthe\u001b[Cexisting\u001b[Cjokes.md.\r\n\u001b[K\u001b[21;3H\u001b[38;5;246mRan \u001b[1m2\u001b[m\u000f\u001b[38;5;246m shell commands \u001b[39m\r\n\u001b[K\r\n\u001b[38;5;231m\u25cf\u001b[C\u001b[39mjokes.md\u001b[Cdoesn't\u001b[Cexist\u001b[Cyet,\u001b[Cso\u001b[CI'll\u001b[Ccreate\u001b[Cit.\u001b[CLet\u001b[Cme\u001b[Ccheck\u001b[Cwith\u001b[Cthe\u001b[Cadvisor\u001b[Cfirst,\u001b[Cand\u001b[Cdeclare\u001b[Cthe\u001b[Cissue\u001b[Csince\u001b[CGitHub\u001b[Cwrites\u001b[Care\u001b[Cgated.\r\n\u001b[K\u001b[25;2H \u001b[1mAdvising\u001b[C\u001b[m\u000f\u001b[38;5;246musing Opus\u001b[C4.8\u001b[39m\u001b[K\u001b[30;3H"]
